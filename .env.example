# ─────────────────────────────────────────────────────────────────────────────
# TaxMind environment configuration
#
# Copy to `.env` and fill in your Azure values to switch from LOCAL mode to the
# real Foundry IQ + Azure OpenAI path. Leaving these blank runs TaxMind fully in
# LOCAL mode (no keys required) — the app auto-detects the mode at startup.
#
# NEVER commit your filled-in .env. It is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# Force a mode: "azure" or "local". Leave blank to auto-detect from the keys below.
TAXMIND_MODE=

# ── Azure OpenAI ─────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
# Deployment names you created in the Foundry portal:
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-dev
AZURE_OPENAI_DEPLOYMENT_DEMO=gpt-4o-demo

# ── Azure AI Search (backs Foundry IQ) ───────────────────────────────────────
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=gst-knowledge

# ── Foundry IQ knowledge base ────────────────────────────────────────────────
FOUNDRY_IQ_ENDPOINT=
FOUNDRY_IQ_KNOWLEDGE_BASE=taxmind-gst-kb
FOUNDRY_IQ_API_VERSION=2026-05-01-preview

# ── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_UPLOADS_CONTAINER=uploads
AZURE_STORAGE_KNOWLEDGE_CONTAINER=gst-knowledge
